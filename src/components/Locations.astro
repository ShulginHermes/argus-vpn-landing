---
---

<section class="relative py-24 px-4 bg-slate-950 overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">
    <!-- Left Content -->
    <div class="flex-1 text-center lg:text-left">
      <h2 class="text-4xl md:text-6xl font-bold text-white mb-6">Many locations</h2>
      <p class="text-lg text-white/60 max-w-xl">
        We offer a large selection of locations to protect your real IP address. Connect to any of our secure servers worldwide.
      </p>
    </div>

    <!-- Right Visual: Stylized Globe -->
    <div class="flex-1 relative w-full max-w-lg aspect-square flex items-center justify-center">
      <!-- Point Cloud Globe Placeholder -->
      <div class="relative w-64 h-64 md:w-80 md:h-80 rounded-full border-2 border-blue-500/30 flex items-center justify-center shadow-[0_0_60px_rgba(0,255,255,0.2)]">
        <div class="absolute inset-0 rounded-full bg-gradient-to-br from-blue-600/20 to-transparent animate-spin-slow"></div>
        <div class="grid grid-cols-8 gap-2 p-4 opacity-40">
          {Array.from({length: 64}).map(() => (
            <div class="w-1 h-1 bg-blue-400 rounded-full"></div>
          ))}
        </div>
      </div>

      <!-- Callouts -->
      <div class="absolute top-1/4 -left-4 md:-left-12 p-4 glass-card flex items-center gap-3 animate-bounce-slow">
        <div class="text-3xl font-bold text-white">50</div>
        <div class="text-xs text-white/60 uppercase">locations</div>
      </div>
      <div class="absolute bottom-1/3 -right-4 md:-right-12 p-4 glass-card flex items-center gap-3 animate-bounce-slow" style="animation-delay: 1s">
        <div class="text-3xl font-bold text-white">40</div>
        <div class="text-xs text-white/60 uppercase">country locations<br/>around the world</div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-spin-slow {
    animation: spin 20s linear infinite;
  }
  .animate-bounce-slow {
    animation: bounce 4s ease-in-out infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
</style>
