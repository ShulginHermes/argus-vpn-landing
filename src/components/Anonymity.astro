---
---

<section class="relative py-24 px-4 bg-slate-900 overflow-hidden">
  <div class="max-w-7xl mx-auto text-center relative z-10">
    <!-- Glowing sphere background element -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-purple-600/20 rounded-full blur-[100px] -z-10"></div>

    <h2 class="text-4xl md:text-6xl font-bold text-white mb-6">Completely anonymous</h2>
    <p class="text-lg text-white/60 max-w-2xl mx-auto mb-16">
      Our goal is to ensure the privacy of each user. We will do our best to protect you from unwanted tracking.
    </p>

    <!-- Feature Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {[
        { label: "IP address", icon: "🌐" },
        { label: "Visited sites", icon: "🛡️" },
        { label: "Browser history", icon: "📂" },
        { label: "Band frequencies", icon: "🕒" },
        { label: "Duration of session", icon: "📈" },
      ].map((item) => (
        <div class="glass-card p-8 flex flex-col items-center text-center hover:bg-white/10 transition-colors group">
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">{item.icon}</div>
          <div class="text-sm font-medium text-white/80">{item.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
